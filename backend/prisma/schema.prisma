generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  MENTOR
  PLACEMENT_OFFICER
  ADMIN
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SkillCategory {
  PROGRAMMING
  FRAMEWORKS
  DATABASES
  CLOUD
  AI_ML
  SOFT_SKILLS
  SECURITY
  DEVOPS
}

enum CareerTrack {
  SOFTWARE_ENGINEER
  DATA_SCIENTIST
  AI_ENGINEER
  CYBERSECURITY_ANALYST
  CLOUD_ENGINEER
  DEVOPS_ENGINEER
  FULL_STACK_DEVELOPER
}

enum RoadmapStatus {
  DRAFT
  GENERATING
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum MilestoneDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  ROADMAP
  MENTOR
  REMINDER
  SYSTEM
}

enum AnalyticsEventType {
  ACCOUNT_REGISTERED
  PROFILE_COMPLETED
  GOAL_SELECTED
  ROADMAP_GENERATED
  MILESTONE_COMPLETED
  PROJECT_COMPLETED
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(STUDENT)
  profileImage String?
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile          CareerProfile?
  careerGoals      CareerGoal[]
  userSkills       UserSkill[]
  gapAnalyses      GapAnalysis[]
  roadmaps         Roadmap[]
  progressUpdates  ProgressUpdate[]
  notifications    Notification[]
  analyticsEvents  AnalyticsEvent[]
  mentorReviews    MentorReview[]   @relation("MentorReviews")
  studentReviews   MentorReview[]   @relation("StudentReviews")
  refreshTokens    RefreshToken[]
  verificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]

  @@index([email])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CareerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  education       String?
  university      String?
  degree          String?
  cgpa            Float?
  graduationYear  Int?
  experience      Json?
  certifications  String[] @default([])
  interests       String[] @default([])
  learningStyle   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CareerPath {
  id              String      @id @default(uuid())
  track           CareerTrack @unique
  title           String
  description     String
  salaryRange     String?
  growthRate      String?
  demandLevel     String?
  requiredSkills  String[]    @default([])
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  careerGoals      CareerGoal[]
  templates        RoadmapTemplate[]
  careerPathSkills CareerPathSkill[]
}

model CareerGoal {
  id             String      @id @default(uuid())
  userId         String
  careerPathId   String?
  careerGoal     CareerTrack
  targetTimeline String?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  careerPath CareerPath? @relation(fields: [careerPathId], references: [id], onDelete: SetNull)
  roadmaps   Roadmap[]

  @@index([userId])
  @@index([careerGoal])
}

model Skill {
  id        String        @id @default(uuid())
  name      String        @unique
  category  SkillCategory
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  userSkills UserSkill[]
  careerPathSkills CareerPathSkill[]

  @@index([category])
}

model CareerPathSkill {
  id           String      @id @default(uuid())
  careerPathId String
  skillId      String
  minLevel     SkillLevel  @default(INTERMEDIATE)

  careerPath CareerPath @relation(fields: [careerPathId], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([careerPathId, skillId])
}

model UserSkill {
  id        String     @id @default(uuid())
  userId    String
  skillId   String
  level     SkillLevel @default(BEGINNER)
  score     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@index([userId])
}

model GapAnalysis {
  id              String   @id @default(uuid())
  userId          String
  careerGoal      CareerTrack
  readinessScore  Int
  strengths       Json
  weaknesses      Json
  missingSkills   Json
  recommendations Json
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Roadmap {
  id           String        @id @default(uuid())
  userId       String
  careerGoalId String?
  status       RoadmapStatus @default(DRAFT)
  aiMetadata   Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  careerGoal   CareerGoal?   @relation(fields: [careerGoalId], references: [id], onDelete: SetNull)
  milestones   Milestone[]
  mentorReviews MentorReview[]

  @@index([userId])
  @@index([status])
}

model Milestone {
  id              String              @id @default(uuid())
  roadmapId       String
  title           String
  description     String
  phase           Int                 @default(1)
  difficulty      MilestoneDifficulty @default(INTERMEDIATE)
  estimatedHours  Int                 @default(0)
  status          MilestoneStatus     @default(NOT_STARTED)
  resources       Json?
  orderIndex      Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  roadmap         Roadmap          @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  progressUpdates ProgressUpdate[]

  @@index([roadmapId])
  @@index([status])
}

model Project {
  id                String              @id @default(uuid())
  title             String
  description       String
  difficulty        MilestoneDifficulty @default(INTERMEDIATE)
  skillsCovered     String[]            @default([])
  estimatedDuration String?
  category          String?
  popularity        Int                 @default(0)
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([difficulty])
}

model ProgressUpdate {
  id                   String   @id @default(uuid())
  userId               String
  milestoneId          String
  completionPercentage Int      @default(0)
  notes                String?
  evidenceUrl          String?
  createdAt            DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([milestoneId])
}

model MentorReview {
  id         String       @id @default(uuid())
  mentorId   String
  studentId  String
  roadmapId  String
  comments   String
  rating     Int?
  status     ReviewStatus @default(PENDING)
  suggestions String[]    @default([])
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  mentor  User    @relation("MentorReviews", fields: [mentorId], references: [id], onDelete: Cascade)
  student User    @relation("StudentReviews", fields: [studentId], references: [id], onDelete: Cascade)
  roadmap Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([mentorId])
  @@index([studentId])
  @@index([roadmapId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model AnalyticsEvent {
  id        String             @id @default(uuid())
  userId    String?
  eventType AnalyticsEventType
  metadata  Json?
  createdAt DateTime           @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([createdAt])
}

model RoadmapTemplate {
  id           String      @id @default(uuid())
  careerPathId String
  name         String
  description  String?
  milestones   Json
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  careerPath CareerPath @relation(fields: [careerPathId], references: [id], onDelete: Cascade)

  @@index([careerPathId])
}

model BackgroundJob {
  id          String    @id @default(uuid())
  queueName   String
  jobId       String
  status      JobStatus @default(QUEUED)
  payload     Json?
  result      Json?
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([queueName])
  @@index([status])
}
